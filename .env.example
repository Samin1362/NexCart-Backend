# ─────────────────────────────────────────────
# NexCart API — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

NODE_ENV=development
PORT=5001

# ── MongoDB Atlas ──────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/nexcart?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend origin (CORS) ─────────────────────
# Development:  http://localhost:3000
# Production:   https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ── Google Gemini AI ───────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Firebase Admin SDK ─────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key exactly as shown in the Firebase JSON file.
# On Render, replace literal \n with actual newlines in the dashboard.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
